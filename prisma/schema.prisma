generator client {
  provider = "prisma-client"
  output   = "../src/generated/db"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  createdAt    DateTime   @default(now()) @map("created_at")
  campaigns    Campaign[]

  @@map("users")
}

model Campaign {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  name            String
  niche           String
  searchQuery     String   @map("search_query")
  serpKeyword     String   @map("serp_keyword")
  country         String
  city            String
  stateRegion     String?  @map("state_region")
  leadTarget      Int      @map("lead_target")
  overscrapeMult  Decimal  @default(2.5) @map("overscrape_mult")
  isTest          Boolean  @default(false) @map("is_test")
  status          String   @default("DRAFT")
  exportStatus    Json     @default("{}") @map("export_status")
  outscraperId    String?  @map("outscraper_id")
  outscraperRaw   Json?    @map("outscraper_raw")
  totalScraped    Int      @default(0) @map("total_scraped")
  totalFiltered   Int      @default(0) @map("total_filtered")
  totalParked     Int      @default(0) @map("total_parked")
  totalEnriched   Int      @default(0) @map("total_enriched")
  totalFailed     Int      @default(0) @map("total_failed")
  pipelineStartedAt DateTime? @map("pipeline_started_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id])
  leads    Lead[]
  jobLogs  JobLog[]

  @@map("campaigns")
}

model Lead {
  id         String @id @default(uuid())
  campaignId String @map("campaign_id")
  status     String @default("SCRAPED")

  businessName    String?  @map("business_name")
  businessNameRaw String?  @map("business_name_raw")
  contactName     String?  @map("contact_name")
  firstName       String?  @map("first_name")
  email           String?
  email2          String?  @map("email_2")
  email3          String?  @map("email_3")
  emailType       String?  @map("email_type")
  phone           String?
  website         String?
  websiteRaw      String?  @map("website_raw")
  websiteDisplay  String?  @map("website_display")
  address         String?
  city            String?
  country         String?
  googleRating    Decimal? @map("google_rating") @db.Decimal(2, 1)
  reviewCount     Int?     @map("review_count")
  reviewsPerScore Json?    @map("reviews_per_score")
  businessHours   Json?    @map("business_hours")
  businessCategory String? @map("business_category")
  isVerified      Boolean? @map("is_verified")
  googleMapsUrl   String?  @map("google_maps_url")
  googlePlaceId   String?  @map("google_place_id")
  facebookUrl     String?  @map("facebook_url")
  instagramUrl    String?  @map("instagram_url")
  linkedinUrl     String?  @map("linkedin_url")

  pagespeedScore    Int?      @map("pagespeed_score")
  pagespeedMobile   String?   @map("pagespeed_mobile")
  pagespeedLcp      Decimal?  @map("pagespeed_lcp")
  pagespeedInp      Decimal?  @map("pagespeed_inp")
  pagespeedCls      Decimal?  @map("pagespeed_cls")
  pagespeedLoadTime Decimal?  @map("pagespeed_load_time")
  pagespeedIssues   Json?     @map("pagespeed_issues")
  pagespeedFetchedAt DateTime? @map("pagespeed_fetched_at")

  inLocalPack       Boolean?  @map("in_local_pack")
  localPackPosition Int?      @map("local_pack_position")
  localPackExists   Boolean?  @map("local_pack_exists")
  searchQueryUsed   String?   @map("search_query_used")
  searchLocation    String?   @map("search_location")
  competitor1Name   String?   @map("competitor_1_name")
  competitor1Rating Decimal?  @map("competitor_1_rating")
  competitor1Reviews Int?     @map("competitor_1_reviews")
  competitor2Name   String?   @map("competitor_2_name")
  competitor2Rating Decimal?  @map("competitor_2_rating")
  competitor2Reviews Int?     @map("competitor_2_reviews")
  competitor3Name   String?   @map("competitor_3_name")
  competitor3Rating Decimal?  @map("competitor_3_rating")
  competitor3Reviews Int?     @map("competitor_3_reviews")
  hasPaidAds        Boolean?  @map("has_paid_ads")
  serpFetchedAt     DateTime? @map("serp_fetched_at")

  batchAvgRating  Decimal? @map("batch_avg_rating")
  batchAvgReviews Int?     @map("batch_avg_reviews")
  batchRank       Int?     @map("batch_rank")

  category         String?
  scoreInvisible   Decimal? @map("score_invisible")
  scoreReviews     Decimal? @map("score_reviews")
  scoreSlowsite    Decimal? @map("score_slowsite")
  scoreNowebsite   Decimal? @map("score_nowebsite")
  scoreStrongnoads Decimal? @map("score_strongnoads")

  exportedAt       DateTime? @map("exported_at")
  instantlyCampaign String?  @map("instantly_campaign")

  errorMessage String?   @map("error_message")
  errorStep    String?   @map("error_step")
  retryCount   Int       @default(0) @map("retry_count")
  maxRetries   Int       @default(3) @map("max_retries")
  lastErrorAt  DateTime? @map("last_error_at")

  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  jobLogs  JobLog[]

  @@index([campaignId, status])
  @@index([campaignId, category])
  @@index([email])
  @@index([googlePlaceId])
  @@map("leads")
}

model Template {
  id             String   @id @default(uuid())
  category       String
  sequenceNumber Int      @map("sequence_number")
  subject        String
  body           String
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([category, sequenceNumber])
  @@index([category, sequenceNumber])
  @@map("templates")
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model SerpCache {
  id           String   @id @default(uuid())
  cacheKey     String   @unique @map("cache_key")
  keyword      String
  locationName String   @map("location_name")
  response     Json
  localPack    Json?    @map("local_pack")
  paidResults  Json?    @map("paid_results")
  fetchedAt    DateTime @default(now()) @map("fetched_at")
  expiresAt    DateTime @map("expires_at")

  @@index([cacheKey, expiresAt])
  @@map("serp_cache")
}

model JobLog {
  id         String   @id @default(uuid())
  campaignId String   @map("campaign_id")
  leadId     String?  @map("lead_id")
  action     String
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead     Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("job_logs")
}
